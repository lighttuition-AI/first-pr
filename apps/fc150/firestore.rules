rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PROTOTYPE rules — open read/write so the TestFlight build works without an
    // auth step yet. TODO (next milestone): enable Firebase Auth (anonymous +
    // email/Apple), then restrict writes — players edit only their own doc;
    // rosters/broadcasts/season writes require an admin custom claim.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
