rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reads stay open so every installed build keeps showing live data; writes
    // require a signed-in session (anonymous is enough). Next step once the
    // registration build is verified on-device: require auth for reads too
    // (see firestore.rules.authed) and scope roster/broadcast writes to admins.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
