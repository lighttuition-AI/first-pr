rules_version = '2';

// Hargeisa Parking — Firestore security rules.
//
// Enforces the officer-approval gate in the database (not just the UI):
//  - Officer records are keyed by the officer's auth UID.
//  - An officer can create ONLY their own record, and only as `pending`.
//  - Only an admin (custom claim `admin == true`) can approve/reject/suspend.
//  - Only an APPROVED officer can write citations.
// See FIREBASE_SETUP.md for granting the admin claim.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.admin == true; }

    function isApprovedOfficer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/officers/$(request.auth.uid))
        && get(/databases/$(database)/documents/officers/$(request.auth.uid)).data.status == 'approved';
    }

    // Officer records, keyed by auth UID. Self-create as pending; admins decide.
    match /officers/{officerId} {
      allow read:           if isAdmin() || (isSignedIn() && request.auth.uid == officerId);
      allow create:         if isSignedIn() && request.auth.uid == officerId
                            && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // Citizen profiles — each citizen owns only their own record.
    match /citizens/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Sequential badge-number counter (written during signup).
    match /counters/{id} {
      allow read, write: if isSignedIn();
    }

    // Vehicle database — any signed-in user may look up; only admins manage.
    match /vehicles/{plate} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Citations — only an APPROVED officer may issue; admins may amend.
    match /citations/{citationId} {
      allow read:           if isSignedIn();
      allow create:         if isApprovedOfficer();
      allow update, delete: if isAdmin();
    }

    // Appeals — a citizen submits (must start as 'review'); admins decide.
    match /appeals/{appealId} {
      allow read:           if isSignedIn();
      allow create:         if isSignedIn() && request.resource.data.status == 'review';
      allow update, delete: if isAdmin();
    }
  }
}
