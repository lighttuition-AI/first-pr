rules_version = '2';

// Hargeisa Parking — Firestore security rules.
//
// Enforces the officer-approval gate in the database (not just the UI):
//  - Officer records are keyed by the officer's auth UID.
//  - An officer can create ONLY their own record, and only as `pending`.
//  - Only an admin (custom claim `admin == true`) can approve/reject/suspend.
//  - Only an APPROVED officer can write citations.
// See FIREBASE_SETUP.md for granting the admin claim.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // Admin = the bootstrap custom claim, OR a legacy `admins/{uid}` member, OR a
    // `dashboardUsers/{uid}` record with role 'admin'. The collection paths let an
    // existing admin add others without a backend (no Cloud Function needed); the
    // claim path bootstraps it.
    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.admin == true
            || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            || (exists(/databases/$(database)/documents/dashboardUsers/$(request.auth.uid))
                && get(/databases/$(database)/documents/dashboardUsers/$(request.auth.uid)).data.role == 'admin'));
    }

    // Any provisioned dashboard account (admin OR normal user). Normal users may
    // browse + look up, but every write stays gated behind isAdmin().
    function isDashboardUser() {
      return isAdmin()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/dashboardUsers/$(request.auth.uid)));
    }

    function isApprovedOfficer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/officers/$(request.auth.uid))
        && get(/databases/$(database)/documents/officers/$(request.auth.uid)).data.status == 'approved';
    }

    // Officer records, keyed by auth UID. Self-create as pending; admins decide.
    // Dashboard users (admins + normal operators) may read the roster.
    match /officers/{officerId} {
      allow read:           if isDashboardUser() || (isSignedIn() && request.auth.uid == officerId);
      allow create:         if isSignedIn() && request.auth.uid == officerId
                            && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // Citizen profiles — each citizen owns only their own record.
    match /citizens/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Sequential badge-number counter (written during signup).
    match /counters/{id} {
      allow read, write: if isSignedIn();
    }

    // Vehicle database — any signed-in user may look up; only admins manage.
    match /vehicles/{plate} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Citations — only an APPROVED officer may issue. Admins may amend freely;
    // a citizen may only flip the status of a citation to 'paid' or
    // 'appealReview' (paying / appealing their own ticket) — nothing else.
    match /citations/{citationId} {
      allow read:   if isSignedIn();
      allow create: if isApprovedOfficer();
      allow update: if isAdmin()
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                        && request.resource.data.status in ['paid', 'appealReview']);
      allow delete: if isAdmin();
    }

    // Appeals — a citizen submits (must start as 'review'); admins decide.
    match /appeals/{appealId} {
      allow read:           if isSignedIn();
      allow create:         if isSignedIn() && request.resource.data.status == 'review';
      allow update, delete: if isAdmin();
    }

    // District shop deals — any signed-in user reads; only admins manage.
    match /deals/{dealId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Legacy dashboard admin accounts. Membership here grants admin powers
    // (see isAdmin). Only an existing admin can add or remove admins.
    match /admins/{uid} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Dashboard accounts with a role ('admin' | 'user'). Only an admin can
    // create/remove accounts; any signed-in user may read (needed so the app can
    // resolve its own role at sign-in).
    match /dashboardUsers/{uid} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Append-only activity / audit log — only admins may read (it is closed off
    // to normal users); any signed-in user may append; entries are immutable.
    match /audit/{id} {
      allow read:           if isAdmin();
      allow create:         if isSignedIn();
      allow update, delete: if false;
    }
  }
}
